CONFIG_ENV=config.env

# إعدادات جهاز Mi 11 Ultra (star)
KERNEL_SOURCE=https://github.com/MiCode/Xiaomi_Kernel_OpenSource
KERNEL_SOURCE_BRANCH=star-r-oss
KERNEL_CONFIG=star_defconfig
KERNEL_IMAGE_NAME=Image.gz-dtb
ARCH=arm64
ADD_LOCALVERSION_TO_FILENAME=true
EXTRA_CMDS:LD=ld.lld

# Clang الإعدادات لـ HyperOS أندرويد 14
USE_CUSTOM_CLANG=false
CUSTOM_CMDS:CLANG_TRIPLE=aarch64-linux-gnu-

## AOSP Clang
CLANG_BRANCH=master-kernel-build-2022
CLANG_VERSION=r487747c

# GCC
ENABLE_GCC_ARM64=true
ENABLE_GCC_ARM32=true

# KernelSU flags (تفعيل الروت)
ENABLE_KERNELSU=true
KERNELSU_TAG=v0.9.5
KSU_EXPECTED_SIZE=
KSU_EXPECTED_HASH=

# Configuration - تفعيل المميزات المطلوبة لـ KSU
DISABLE-LTO=false
DISABLE_CC_WERROR=false
ADD_KPROBES_CONFIG=true
ADD_OVERLAYFS_CONFIG=true
APPLY_KSU_PATCH=true
REMOVE_UNUSED_PACKAGES=true

# AnyKernel3
USE_CUSTOM_ANYKERNEL3=false

# Ccache
ENABLE_CCACHE=true

# DTBO image
NEED_DTBO=false

# بناء ملف boot.img (اختياري، يفضل استخدام AnyKernel3)
BUILD_BOOT_IMG=false
SOURCE_BOOT_IMAGE=
