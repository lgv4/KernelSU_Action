CONFIG_ENV=config.env

# إعدادات Mi 11 Ultra (star)
KERNEL_SOURCE=https://github.com/MiCode/Xiaomi_Kernel_OpenSource
KERNEL_SOURCE_BRANCH=star-r-oss
KERNEL_CONFIG=star_defconfig
KERNEL_IMAGE_NAME=Image.gz-dtb
ARCH=arm64
ADD_LOCALVERSION_TO_FILENAME=true

# استخدام Clang خارجي مضمون (تجاوزاً لسيرفرات جوجل)
USE_CUSTOM_CLANG=true
CUSTOM_CLANG_SOURCE=https://github.com/dakkshesh07/google-clang/static/clang-r416183b1.tar.gz

# GCC
ENABLE_GCC_ARM64=true
ENABLE_GCC_ARM32=true

# KernelSU
ENABLE_KERNELSU=true
KERNELSU_TAG=v0.9.5

# Configuration
ADD_KPROBES_CONFIG=true
ADD_OVERLAYFS_CONFIG=true
APPLY_KSU_PATCH=true

# AnyKernel3
USE_CUSTOM_ANYKERNEL3=false
ENABLE_CCACHE=true
BUILD_BOOT_IMG=false
